import os;
import str;

print("--- Argument Injection Test (v1.7) ---");

# Capture the arguments that the OS sent to the binary
const arguments = os.args();

const qty = len(arguments);
print($"Total arguments received: {to_str(qty)}");

print("\nDumping arguments:");

for arg in arguments {
    print(" -> " ~> str.concat(arg));
}