import os;
import str;

"--- Argument Injection Test (v1.14) ---" ~> print();

-- Capture the arguments that the OS sent to the binary
const arguments = os.args();

const qty = arguments ~> len();
"Total arguments received: " ~> concat(qty ~> to_str()) ~> print();

"\nDumping arguments:" ~> print();

for arg in arguments {
    " -> " ~> concat(arg) ~> print();
}