#!/usr/bin/make -f
%:
	dh $@

override_dh_auto_build:
	# Pre-compiled binary — nothing to build.

override_dh_auto_install:
	install -D -m 0755 zig-out/bin/flint \
		$(CURDIR)/debian/flint/usr/bin/flint
	install -d $(CURDIR)/debian/flint/usr/share/flint/std
	cp -r std/. $(CURDIR)/debian/flint/usr/share/flint/std/

override_dh_auto_test:
	# Skip tests during packaging.