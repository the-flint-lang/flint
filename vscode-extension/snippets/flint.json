{
    "Define Struct": {
        "prefix": "struct",
        "body": [
            "struct ${1:Name} {",
            "    ${2:field}: ${3|string,int,bool,val|}",
            "}"
        ],
        "description": "Declare a strongly typed custom Struct"
    },
    "Fetch API Pipeline": {
        "prefix": "fetch",
        "body": [
            "const ${1:data} = http.fetch(\"${2:https://api.example.com}\")",
            "    ~> parse_json(_)",
            "    ~> ensure(_[\"status\"] == 200, \"API Error\")",
            "    ~> expect(\"Network Failure\");$0"
        ],
        "description": "Modern Fetch pipeline with JSON parsing and safety"
    },
    "String Interpolation": {
        "prefix": "interp",
        "body": [
            "const ${1:msg} = $\"Value is: {${2:expression}}\";$0"
        ],
        "description": "Create an interpolated string"
    },
    "Multiline Interpolation": {
        "prefix": "html",
        "body": [
            "const ${1:template} = $`",
            "<div>",
            "    <h1>{${2:title}}</h1>",
            "</div>",
            "`;$0"
        ],
        "description": "Create a multiline interpolated template"
    },
    "Iterate Directory Modern": {
        "prefix": "ls",
        "body": [
            "const ${1:files} = os.ls(\"${2:.}\") ~> expect(\"Failed to list directory.\");",
            "",
            "for f in to_str(${1:files}) ~> lines() {",
            "    if (os.is_file(f)) {",
            "        print($\"File: {f} | Size: {os.file_size(f)}\");",
            "        $0",
            "    }",
            "}"
        ],
        "description": "List directory using interpolation and modern indexing"
    }
}