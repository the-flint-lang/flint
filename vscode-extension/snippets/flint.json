{
    "Define Struct": {
        "prefix": "struct",
        "body": [
            "struct ${1:Name} {",
            "    ${2:field}: ${3|string,int,bool,val|}",
            "}"
        ],
        "description": "Declare a strongly typed custom Struct"
    },
    "Fetch API Call": {
        "prefix": "fetch",
        "body": [
            "const ${1:payload} = net.fetch(\"${2:https://api.example.com}\") catch |err| {",
            "    io.print(\"Network Error: \");",
            "    io.print(err);",
            "    os.exit(1);",
            "};"
        ],
        "description": "Make an HTTP request with safe error handling"
    },
    "Parse JSON to Struct": {
        "prefix": "parse",
        "body": [
            "const ${1:obj} = json.parse_as(${2:StructName}, ${3:payload});"
        ],
        "description": "Parse JSON string directly into a typed Struct"
    },
    "Execute OS Command (Raw)": {
        "prefix": "exec",
        "body": [
            "const ${1:output} = os.exec(\"${2:ls -la}\");"
        ],
        "description": "Run an OS command and get stdout as string (Fast/Raw)"
    },
    "Read File Pipeline": {
        "prefix": "read",
        "body": [
            "const ${1:content} = io.read_file(\"${2:data.log}\") catch |err| {",
            "   io.print(err);",
            "   os.exit(1);",
            "};"
        ],
        "description": "Read a file from disk with zero-copy mmap"
    },
    "Spawn Process (Dict)": {
        "prefix": "spawn",
        "body": [
            "const ${1:proc} = os.spawn(\"${2:process_command}\") catch |err| {",
            "    io.print(\"KERNEL ERROR: Unable to spawn process\");",
            "    io.print(err);",
            "    os.exit(1);",
            "};",
            "const ${3:code} = to_int(get(${1:proc}, \"exit_code\"));",
            "const ${4:out} = to_str(get(${1:proc}, \"stdout\"));$0"
        ],
        "description": "Orchestrate a subprocess safely, returning a Dict"
    },
    "Zero-Copy File Clone": {
        "prefix": "copy",
        "body": [
            "_ = os.copy(\"${1:source.txt}\", \"${2:dest.txt}\") catch |err| {",
            "    io.print(\"IO Error: \");",
            "    io.print(err);",
            "    os.exit(1);",
            "};$0"
        ],
        "description": "Clone a file using Kernel Space zero-copy (sendfile)"
    },
    "Iterate Directory Metadata": {
        "prefix": "ls",
        "body": [
            "const ${1:files} = os.ls(\"${2:.}\") catch |err| {",
            "    io.print(err);",
            "    os.exit(1);",
            "};",
            "",
            "for f in to_str(${1:files}) ~> str.lines() {",
            "    if (os.is_file(f)) {",
            "        const ${3:size} = os.file_size(f);",
            "        $0",
            "    }",
            "}"
        ],
        "description": "List directory and iterate over files with O(1) stack allocation stat calls"
    },
    "Import Statement": {
        "prefix": "imp",
        "body": [
            "import \"${1:std/io.fl}\" as ${2:io};"
        ],
        "description": "Import statement"
    }
}