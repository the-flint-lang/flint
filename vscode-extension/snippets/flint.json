{
    "Define Struct": {
        "prefix": "struct",
        "body": [
            "struct ${1:Name} {",
            "    ${2:field}: ${3|string,int,bool|}",
            "}"
        ],
        "description": "Declare a strongly typed custom Struct"
    },
    "Fetch API Call": {
        "prefix": "fetch",
        "body": [
            "const ${1:payload} = fetch(\"${2:https://api.example.com}\") catch |err| {",
            "    print(\"Network Error: \");",
            "    print(err);",
            "    exit(1);",
            "};"
        ],
        "description": "Make an HTTP request with safe error handling"
    },
    "Parse JSON to Struct": {
        "prefix": "parse",
        "body": [
            "const ${1:obj} = parse_json_as(${2:StructName}, ${3:payload});"
        ],
        "description": "Parse JSON string directly into a typed Struct"
    },
    "Execute OS Command": {
        "prefix": "exec",
        "body": [
            "exec(\"${1:ls -la}\")",
            "    ~> lines()",
            "    ~> grep(\"${2:pattern}\")",
            "    ~> print();"
        ],
        "description": "Run an OS command and process output via pipeline"
    },
    "Read File Pipeline": {
        "prefix": "read",
        "body": [
            "read_file(\"${1:data.log}\")",
            "    ~> lines()",
            "    ~> print();"
        ],
        "description": "Read a file from disk with zero-copy mmap"
    }
}