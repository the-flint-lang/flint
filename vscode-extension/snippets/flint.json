{
    "Define Struct": {
        "prefix": "struct",
        "body": [
            "struct ${1:Name} {",
            "    ${2:field}: ${3|string,int,float,bool,val|}",
            "}"
        ],
        "description": "Declares a strongly typed Struct"
    },
    "Import Module": {
        "prefix": "import",
        "body": [
            "import ${1|os,fs,io,process,str,http,json,term,utils,env,sys|};"
        ],
        "description": "Imports a Flint stdlib module"
    },
    "String Interpolation": {
        "prefix": "interp",
        "body": [
            "const ${1:msg} = $\"${2:text} {${3:expression}}\";$0"
        ],
        "description": "Creates an interpolated string with $\""
    },
    "Multiline Template String": {
        "prefix": "tmpl",
        "body": [
            "const ${1:template} = $`",
            "${2:content {${3:variable}}}",
            "`;$0"
        ],
        "description": "Creates a multiline template string with $`"
    },
    "Fetch + JSON Pipeline": {
        "prefix": "fetch",
        "body": [
            "const ${1:data} = http.fetch(\"${2:https://api.example.com}\")",
            "    ~> json.parse()",
            "    ~> ensure(_[\"${3:status}\"] == 200, \"API Error\")",
            "    ~> if_fail(\"Network Failure\");$0"
        ],
        "description": "HTTP fetch pipeline with JSON parsing and validation"
    },
    "Safe File Read (catch)": {
        "prefix": "read_catch",
        "body": [
            "const ${1:content} = fs.read_file(\"${2:data.txt}\") catch |${3:err}| {",
            "    printerr($\"Failed to read file: {${3:err}}\");",
            "    process.exit(1);",
            "};$0"
        ],
        "description": "Reads a file with error handling via catch"
    },
    "Safe File Read (if_fail)": {
        "prefix": "read_fail",
        "body": [
            "const ${1:content} = fs.read_file(\"${2:data.txt}\") ~> if_fail(\"${3:Failed to read file}\");$0"
        ],
        "description": "Reads a file and stops the pipeline on error"
    },
    "Stream Directory Files": {
        "prefix": "stream_ls",
        "body": [
            "stream ${1:file} in fs.ls(\"${2:.}\") ~> lines() {",
            "    ${1:file} ~> $0",
            "}"
        ],
        "description": "Iterates over directory files using stream (auto-arena GC)"
    },
    "Lazy JSON Stream": {
        "prefix": "stream_json",
        "body": [
            "const ${1:stream_data} = json.lazy_stream(${2:raw_json_string}, \"${3:array_key}\");",
            "stream ${4:raw_item} in ${1:stream_data} {",
            "    const ${5:obj} = json.parse(to_str(${4:raw_item}));",
            "    $0",
            "}"
        ],
        "description": "High-performance streaming JSON iteration"
    },
    "Type Checking": {
        "prefix": "typeof",
        "body": [
            "if type_of(${1:variable}) == \"${2|string,int,float,bool,null,array,dict,error,stream,unknown|}\" {",
            "    $0",
            "}"
        ],
        "description": "Check the runtime type of a FlintValue"
    },
    "Process Spawn + Assert": {
        "prefix": "spawn",
        "body": [
            "const ${1:result} = process.spawn(\"${2:command}\", true)",
            "    ~> process.assert(\"${3:Command failed}\");$0"
        ],
        "description": "Spawns a subprocess and validates the result"
    },
    "Pipeline with Fallback": {
        "prefix": "fallback",
        "body": [
            "const ${1:value} = ${2:expr}",
            "    ~> fallback(${3:\"default_value\"});$0"
        ],
        "description": "Pipeline with fallback value in case of failure"
    },
    "JSON Parse Pipeline": {
        "prefix": "json_parse",
        "body": [
            "const ${1:data} = fs.read_file(\"${2:data.json}\")",
            "    ~> if_fail(\"Failed to read ${2:data.json}\")",
            "    ~> json.parse();$0"
        ],
        "description": "Safely reads and parses a JSON file"
    },
    "List Directory": {
        "prefix": "ls",
        "body": [
            "const ${1:files} = fs.ls(\"${2:.}\") ~> if_fail(\"Failed to list directory.\");",
            "",
            "for ${3:f} in str.to_str(${1:files}) ~> lines() {",
            "    if fs.is_file(${3:f}) {",
            "        print($\"File: {${3:f}}\");",
            "        $0",
            "    }",
            "}"
        ],
        "description": "Lists a directory and iterates over files"
    },
    "Function Declaration": {
        "prefix": "fn",
        "body": [
            "fn ${1:name}(${2:param}: ${3|string,int,float,bool,val,arr|}) ${4|string,int,float,bool,val,void|} {",
            "    $0",
            "}"
        ],
        "description": "Declares a typed function"
    },
    "If / Else": {
        "prefix": "if",
        "body": [
            "if ${1:condition} {",
            "    $0",
            "} else {",
            "    ",
            "}"
        ],
        "description": "If/else block (optional parentheses in Flint)"
    }
}