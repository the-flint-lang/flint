{
    "name": "flint-lang",
    "displayName": "Flint Language Support",
    "description": "Official syntax highlighting, snippets and file icons for the Flint programming language.",
    "version": "1.14.0",
    "repository": {
        "type": "git",
        "url": "https://github.com/the-flint-lang/flint.git"
    },
    "bugs": {
        "url": "https://github.com/the-flint-lang/flint/issues"
    },
    "homepage": "https://github.com/the-flint-lang/flint",
    "license": "Apache-2.0",
    "icon": "assets/favicon_transparent_bg.png",
    "publisher": "the-flint-lang",
    "engines": {
        "vscode": "^1.75.0"
    },
    "categories": [
        "Programming Languages",
        "Snippets"
    ],
    "keywords": [
        "flint",
        "pipeline",
        "devops",
        "cli",
        "automation",
        "syntax highlighting"
    ],
    "contributes": {
        "languages": [
            {
                "id": "flint",
                "semanticHighlighting": false,
                "aliases": [
                    "Flint",
                    "flint"
                ],
                "extensions": [
                    ".fl"
                ],
                "configuration": "./language-configuration.json",
                "icon": {
                    "light": "./assets/favicon_transparent_bg.png",
                    "dark": "./assets/favicon_transparent_bg.png"
                }
            }
        ],
        "grammars": [
            {
                "language": "flint",
                "scopeName": "source.flint",
                "path": "./syntaxes/flint.tmLanguage.json"
            }
        ],
        "snippets": [
            {
                "language": "flint",
                "path": "./snippets/flint.json"
            }
        ],
        "iconThemes": [
            {
                "id": "flint-icons",
                "label": "Flint File Icons",
                "path": "./fileicons/flint-icon-theme.json"
            }
        ]
    }
}