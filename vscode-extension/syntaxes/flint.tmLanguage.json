{
    "$schema": "../schemas/tmlanguage.json",
    "name": "Flint",
    "patterns": [
        {
            "include": "#comments"
        },
        {
            "include": "#strings"
        },
        {
            "include": "#keywords"
        },
        {
            "include": "#types"
        },
        {
            "include": "#builtins"
        },
        {
            "include": "#function-calls"
        },
        {
            "include": "#namespaces"
        },
        {
            "include": "#operators"
        },
        {
            "include": "#numbers"
        }
    ],
    "repository": {
        "comments": {
            "patterns": [
                {
                    "name": "comment.line.number-sign.flint",
                    "match": "#.*$"
                }
            ]
        },
        "strings": {
            "patterns": [
                {
                    "name": "string.quoted.double.flint",
                    "begin": "(\\$)?\"",
                    "beginCaptures": {
                        "1": {
                            "name": "keyword.control.interpolation.flint"
                        }
                    },
                    "end": "\"",
                    "patterns": [
                        {
                            "name": "constant.character.escape.flint",
                            "match": "\\\\."
                        },
                        {
                            "name": "meta.embedded.line.flint",
                            "begin": "\\{",
                            "beginCaptures": {
                                "0": {
                                    "name": "punctuation.section.embedded.begin.flint"
                                }
                            },
                            "end": "\\}",
                            "endCaptures": {
                                "0": {
                                    "name": "punctuation.section.embedded.end.flint"
                                }
                            },
                            "patterns": [
                                {
                                    "include": "$self"
                                }
                            ]
                        }
                    ]
                },
                {
                    "name": "string.quoted.other.multiline.flint",
                    "begin": "(\\$)?`",
                    "beginCaptures": {
                        "1": {
                            "name": "keyword.control.interpolation.flint"
                        }
                    },
                    "end": "`",
                    "patterns": [
                        {
                            "include": "meta.embedded.line.flint"
                        },
                        {
                            "name": "meta.embedded.block.flint",
                            "begin": "\\{",
                            "beginCaptures": {
                                "0": {
                                    "name": "punctuation.section.embedded.begin.flint"
                                }
                            },
                            "end": "\\}",
                            "endCaptures": {
                                "0": {
                                    "name": "punctuation.section.embedded.end.flint"
                                }
                            },
                            "patterns": [
                                {
                                    "include": "$self"
                                }
                            ]
                        }
                    ]
                }
            ]
        },
        "keywords": {
            "patterns": [
                {
                    "name": "keyword.control.flint",
                    "match": "\\b(if|else|for|in|return|catch)\\b"
                },
                {
                    "name": "keyword.other.flint",
                    "match": "\\b(fn|var|const|import|struct|extern|as)\\b"
                },
                {
                    "name": "constant.language.flint",
                    "match": "\\b(true|false|null)\\b"
                }
            ]
        },
        "types": {
            "patterns": [
                {
                    "name": "storage.type.flint",
                    "match": "\\b(int|string|bool|void|val|arr)\\b"
                }
            ]
        },
        "builtins": {
            "patterns": [
                {
                    "name": "support.function.builtin.flint",
                    "match": "\\b(print|len|push|range|parse_json|parse_json_as|expect|fallback|ensure|to_str)\\b"
                },
                {
                    "name": "variable.language.placeholder.flint",
                    "match": "\\b_\\b"
                }
            ]
        },
        "function-calls": {
            "patterns": [
                {
                    "name": "entity.name.function.flint",
                    "match": "(?<![.])\\b([a-zA-Z_][a-zA-Z0-9_]*)\\s*(?=\\()"
                }
            ]
        },
        "namespaces": {
            "patterns": [
                {
                    "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)(\\.)([ a-zA-Z_][a-zA-Z0-9_]*)\\s*(?=\\()",
                    "captures": {
                        "1": {
                            "name": "entity.name.namespace.flint"
                        },
                        "2": {
                            "name": "punctuation.accessor.flint"
                        },
                        "3": {
                            "name": "entity.name.function.flint"
                        }
                    }
                },
                {
                    "name": "entity.name.namespace.flint",
                    "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)(?=\\.)"
                }
            ]
        },
        "operators": {
            "patterns": [
                {
                    "name": "keyword.operator.pipeline.flint",
                    "match": "~>"
                },
                {
                    "name": "keyword.operator.flint",
                    "match": "(!=|==|<=|>=|~>|\\+|-|\\*|/|%|<|>|=|!|\\|)"
                }
            ]
        },
        "numbers": {
            "patterns": [
                {
                    "name": "constant.numeric.flint",
                    "match": "\\b\\d+(\\.\\d+)?\\b"
                }
            ]
        }
    },
    "scopeName": "source.flint"
}