{
    "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
    "name": "Flint",
    "scopeName": "source.flint",
    "patterns": [
        {
            "include": "#comments"
        },
        {
            "include": "#strings"
        },
        {
            "include": "#keywords"
        },
        {
            "include": "#error_handling"
        },
        {
            "include": "#operators"
        },
        {
            "include": "#functions"
        },
        {
            "include": "#numbers"
        }
    ],
    "repository": {
        "comments": {
            "patterns": [
                {
                    "name": "comment.line.number-sign.flint",
                    "match": "#.*$"
                }
            ]
        },
        "strings": {
            "patterns": [
                {
                    "name": "string.quoted.double.flint",
                    "begin": "\"",
                    "end": "\"",
                    "patterns": [
                        {
                            "name": "constant.character.escape.flint",
                            "match": "\\\\."
                        }
                    ]
                },
                {
                    "name": "string.quoted.other.multiline.flint",
                    "begin": "`",
                    "end": "`"
                }
            ]
        },
        "keywords": {
            "patterns": [
                {
                    "name": "keyword.control.flint",
                    "match": "\\b(if|else|for|in|return|import|catch)\\b"
                },
                {
                    "name": "storage.type.flint",
                    "match": "\\b(fn|const|var|void|string|int|bool)\\b"
                },
                {
                    "name": "constant.language.boolean.flint",
                    "match": "\\b(true|false|null)\\b"
                }
            ]
        },
        "error_handling": {
            "patterns": [
                {
                    "name": "meta.catch.flint",
                    "match": "(\\|)([a-zA-Z_][a-zA-Z0-9_]*)(\\|)",
                    "captures": {
                        "1": {
                            "name": "punctuation.definition.parameters.begin.flint"
                        },
                        "2": {
                            "name": "variable.parameter.error.flint"
                        },
                        "3": {
                            "name": "punctuation.definition.parameters.end.flint"
                        }
                    }
                }
            ]
        },
        "operators": {
            "patterns": [
                {
                    "name": "keyword.control.flow.pipeline.flint",
                    "match": "~>"
                },
                {
                    "name": "keyword.operator.logical.flint",
                    "match": "\\b(not|and|or)\\b"
                },
                {
                    "name": "keyword.operator.comparison.flint",
                    "match": "(==|!=|<=|>=|<|>)"
                },
                {
                    "name": "keyword.operator.assignment.flint",
                    "match": "="
                },
                {
                    "name": "keyword.operator.math.flint",
                    "match": "(\\+|-|\\*|/|%)"
                },
                {
                    "name": "keyword.operator.bitwise.flint",
                    "match": "\\|"
                }
            ]
        },
        "functions": {
            "patterns": [
                {
                    "name": "entity.name.function.flint",
                    "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\s*(?=\\()"
                }
            ]
        },
        "numbers": {
            "patterns": [
                {
                    "name": "constant.numeric.flint",
                    "match": "\\b\\d+(\\.\\d+)?\\b"
                }
            ]
        }
    }
}