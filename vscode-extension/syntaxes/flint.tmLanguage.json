{
    "$schema": "../schemas/tmlanguage.json",
    "name": "Flint",
    "scopeName": "source.flint",
    "fileTypes": [
        "fl"
    ],
    "foldingStartMarker": "\\{\\s*$",
    "foldingStopMarker": "^\\s*\\}",
    "patterns": [
        {
            "include": "#comments"
        },
        {
            "include": "#str"
        },
        {
            "include": "#keywords"
        },
        {
            "include": "#types"
        },
        {
            "include": "#builtins"
        },
        {
            "include": "#numbers"
        },
        {
            "include": "#operators"
        },
        {
            "include": "#namespaces"
        },
        {
            "include": "#function-calls"
        }
    ],
    "repository": {
        "comments": {
            "patterns": [
                {
                    "name": "comment.block.flint",
                    "begin": "\\{-",
                    "beginCaptures": {
                        "0": {
                            "name": "punctuation.definition.comment.flint"
                        }
                    },
                    "end": "-\\}",
                    "endCaptures": {
                        "0": {
                            "name": "punctuation.definition.comment.flint"
                        }
                    },
                    "patterns": [
                        {
                            "include": "#comments"
                        }
                    ]
                },
                {
                    "name": "comment.line.double-dash.flint",
                    "match": "--.*$"
                }
            ]
        },
        "str": {
            "patterns": [
                {
                    "name": "string.quoted.double.interpolated.flint",
                    "contentName": "string.quoted.double.interpolated.flint",
                    "begin": "\\$\"",
                    "beginCaptures": {
                        "0": {
                            "name": "keyword.control.interpolation.flint"
                        }
                    },
                    "end": "\"",
                    "patterns": [
                        {
                            "name": "constant.character.escape.flint",
                            "match": "\\\\."
                        },
                        {
                            "include": "#interpolation"
                        }
                    ]
                },
                {
                    "name": "string.quoted.double.flint",
                    "contentName": "string.quoted.double.flint",
                    "begin": "\"",
                    "end": "\"",
                    "patterns": [
                        {
                            "name": "constant.character.escape.flint",
                            "match": "\\\\."
                        }
                    ]
                },
                {
                    "name": "string.quoted.other.multiline.interpolated.flint",
                    "contentName": "string.quoted.other.multiline.interpolated.flint",
                    "begin": "\\$`",
                    "beginCaptures": {
                        "0": {
                            "name": "keyword.control.interpolation.flint"
                        }
                    },
                    "end": "`",
                    "patterns": [
                        {
                            "name": "constant.character.escape.flint",
                            "match": "\\\\."
                        },
                        {
                            "include": "#interpolation"
                        }
                    ]
                },
                {
                    "name": "string.quoted.other.multiline.flint",
                    "contentName": "string.quoted.other.multiline.flint",
                    "begin": "`",
                    "end": "`",
                    "patterns": [
                        {
                            "name": "constant.character.escape.flint",
                            "match": "\\\\."
                        }
                    ]
                }
            ]
        },
        "interpolation": {
            "patterns": [
                {
                    "name": "meta.embedded.line.flint",
                    "begin": "\\{",
                    "beginCaptures": {
                        "0": {
                            "name": "punctuation.section.embedded.begin.flint"
                        }
                    },
                    "end": "\\}",
                    "endCaptures": {
                        "0": {
                            "name": "punctuation.section.embedded.end.flint"
                        }
                    },
                    "patterns": [
                        {
                            "include": "#keywords"
                        },
                        {
                            "include": "#types"
                        },
                        {
                            "include": "#builtins"
                        },
                        {
                            "include": "#numbers"
                        },
                        {
                            "include": "#operators"
                        },
                        {
                            "include": "#namespaces"
                        },
                        {
                            "include": "#function-calls"
                        }
                    ]
                }
            ]
        },
        "keywords": {
            "patterns": [
                {
                    "name": "keyword.control.flint",
                    "match": "\\b(if|else|and|or|for|while|stream|in|return|catch|break|continue)\\b"
                },
                {
                    "name": "keyword.other.flint",
                    "match": "\\b(fn|var|const|import|struct|extern|as)\\b"
                },
                {
                    "name": "constant.language.flint",
                    "match": "\\b(true|false|null)\\b"
                }
            ]
        },
        "types": {
            "patterns": [
                {
                    "name": "storage.type.flint",
                    "match": "\\b(int|float|string|bool|void|val|arr|dict)\\b"
                }
            ]
        },
        "builtins": {
            "patterns": [
                {
                    "name": "support.function.builtin.flint",
                    "match": "\\b(print|printerr|len|push|range|if_fail|fallback|ensure|to_int|to_str|to_float|clone|lines|chars|grep|embed_file|type_of|concat|parse_json|parse_json_as|val_keys|os_command_exists)\\b"
                },
                {
                    "name": "variable.language.placeholder.flint",
                    "match": "(?<![a-zA-Z0-9_])_(?![a-zA-Z0-9_])"
                }
            ]
        },
        "function-calls": {
            "patterns": [
                {
                    "comment": "Matches function calls but excludes keywords and builtins by relying on order — keywords/builtins are matched first in the top-level patterns array.",
                    "name": "entity.name.function.flint",
                    "match": "(?<![.\\$])\\b([a-zA-Z_][a-zA-Z0-9_]*)\\s*(?=\\()"
                }
            ]
        },
        "namespaces": {
            "patterns": [
                {
                    "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)(\\.)([a-zA-Z_][a-zA-Z0-9_]*)\\s*(?=\\()",
                    "captures": {
                        "1": {
                            "name": "entity.name.namespace.flint"
                        },
                        "2": {
                            "name": "punctuation.accessor.flint"
                        },
                        "3": {
                            "name": "entity.name.function.flint"
                        }
                    }
                },
                {
                    "name": "entity.name.namespace.flint",
                    "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)(?=\\.)"
                }
            ]
        },
        "operators": {
            "patterns": [
                {
                    "name": "keyword.operator.pipeline.flint",
                    "match": "~>"
                },
                {
                    "name": "keyword.operator.range.flint",
                    "match": "\\.\\."
                },
                {
                    "name": "keyword.operator.flint",
                    "match": "(!=|==|<=|>=|\\+|(?<!~)-(?!>)|\\*|/|%|<|>|=|\\?|!(?!=)|\\||:)"
                },
                {
                    "name": "punctuation.operator.flint",
                    "match": "(!(?!=)|\\?)"
                }
            ]
        },
        "numbers": {
            "patterns": [
                {
                    "name": "constant.numeric.flint",
                    "match": "(?<![a-zA-Z_])(?:\\d+(?:\\.\\d*)?|\\.\\d+)(?:[eE][+-]?\\d+)?(?!\\w)"
                }
            ]
        }
    }
}