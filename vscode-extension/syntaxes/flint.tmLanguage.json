{
    "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
    "name": "Flint",
    "patterns": [
        {
            "include": "#comments"
        },
        {
            "include": "#strings"
        },
        {
            "include": "#keywords"
        },
        {
            "include": "#types"
        },
        {
            "include": "#builtins"
        },
        {
            "include": "#operators"
        },
        {
            "include": "#numbers"
        }
    ],
    "repository": {
        "comments": {
            "patterns": [
                {
                    "name": "comment.line.number-sign.flint",
                    "match": "#.*$"
                }
            ]
        },
        "strings": {
            "patterns": [
                {
                    "name": "string.quoted.double.flint",
                    "begin": "\"",
                    "end": "\"",
                    "patterns": [
                        {
                            "name": "constant.character.escape.flint",
                            "match": "\\\\."
                        }
                    ]
                },
                {
                    "name": "string.quoted.other.multiline.flint",
                    "begin": "`",
                    "end": "`"
                }
            ]
        },
        "keywords": {
            "patterns": [
                {
                    "name": "keyword.control.flint",
                    "match": "\\b(if|else|for|in|return|catch)\\b"
                },
                {
                    "name": "keyword.other.flint",
                    "match": "\\b(fn|var|const|import|struct)\\b"
                },
                {
                    "name": "constant.language.flint",
                    "match": "\\b(true|false|null)\\b"
                }
            ]
        },
        "types": {
            "patterns": [
                {
                    "name": "support.type.flint",
                    "match": "\\b(int|string|bool|void)\\b"
                }
            ]
        },
        "builtins": {
            "patterns": [
                {
                    "name": "support.function.builtin.flint",
                    "match": "\\b(print|read_file|write_file|lines|grep|join|args|file_exists|exit|env|exec|len|range|push|trim|split|replace|fetch|parse_json|parse_json_as|int_to_str|concat|to_str|is_err|get_err|count_matches|get|set)\\b(?=\\s*\\()"
                }
            ]
        },
        "operators": {
            "patterns": [
                {
                    "name": "keyword.operator.pipeline.flint",
                    "match": "~>"
                },
                {
                    "name": "keyword.operator.flint",
                    "match": "(\\+|-|\\*|/|%|==|!=|<=|>=|<|>|=|\\|)"
                }
            ]
        },
        "numbers": {
            "patterns": [
                {
                    "name": "constant.numeric.flint",
                    "match": "\\b\\d+(\\.\\d+)?\\b"
                }
            ]
        }
    },
    "scopeName": "source.flint"
}