{
    "$schema": "../schemas/tmlanguage.json",
    "name": "Flint",
    "patterns": [
        {
            "include": "#comments"
        },
        {
            "include": "#strings"
        },
        {
            "include": "#keywords"
        },
        {
            "include": "#types"
        },
        {
            "include": "#builtins"
        },
        {
            "include": "#operators"
        },
        {
            "include": "#numbers"
        }
    ],
    "repository": {
        "comments": {
            "patterns": [
                {
                    "name": "comment.line.number-sign.flint",
                    "match": "#.*$"
                }
            ]
        },
        "strings": {
            "patterns": [
                {
                    "name": "string.quoted.double.flint",
                    "begin": "\"",
                    "end": "\"",
                    "patterns": [
                        {
                            "name": "constant.character.escape.flint",
                            "match": "\\\\."
                        }
                    ]
                },
                {
                    "name": "string.quoted.other.multiline.flint",
                    "begin": "`",
                    "end": "`"
                }
            ]
        },
        "keywords": {
            "patterns": [
                {
                    "name": "keyword.control.flint",
                    "match": "\\b(if|else|for|in|return|catch)\\b"
                },
                {
                    "name": "keyword.other.flint",
                    "match": "\\b(fn|var|const|import|struct)\\b"
                },
                {
                    "name": "constant.language.flint",
                    "match": "\\b(true|false|null)\\b"
                }
            ]
        },
        "types": {
            "patterns": [
                {
                    "name": "support.type.flint",
                    "match": "\\b(int|string|bool|void)\\b"
                }
            ]
        },
        "builtins": {
            "patterns": [
                {
                    "name": "support.function.builtin.flint",
                    "match": "\\b(grep|join|trim|split|replace|concat|get|set|count_matches|to_str|int_to_str|to_int|lines|args|len|range|push|print|exec|spawn|read_file|write_file|file_exists|mkdir|rm|mv|copy|rm_dir|touch|ls|is_dir|is_file|file_size|env|exit|fetch|parse_json|is_err|get_err)\\b(?=\\s*\\()"
                }
            ]
        },
        "operators": {
            "patterns": [
                {
                    "name": "keyword.operator.pipeline.flint",
                    "match": "~>"
                },
                {
                    "name": "keyword.operator.flint",
                    "match": "(\\+|-|\\*|/|%|==|!=|<=|>=|<|>|=|\\|)"
                }
            ]
        },
        "numbers": {
            "patterns": [
                {
                    "name": "constant.numeric.flint",
                    "match": "\\b\\d+(\\.\\d+)?\\b"
                }
            ]
        }
    },
    "scopeName": "source.flint"
}