{
    "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
    "name": "Flint",
    "scopeName": "source.flint",
    "patterns": [
        {
            "include": "#comments"
        },
        {
            "include": "#strings"
        },
        {
            "include": "#keywords"
        },
        {
            "include": "#operators"
        },
        {
            "include": "#functions"
        },
        {
            "include": "#numbers"
        }
    ],
    "repository": {
        "comments": {
            "patterns": [
                {
                    "name": "comment.line.number-sign.flint",
                    "match": "#.*$"
                }
            ]
        },
        "strings": {
            "patterns": [
                {
                    "name": "string.quoted.double.flint",
                    "begin": "\"",
                    "end": "\"",
                    "patterns": [
                        {
                            "name": "constant.character.escape.flint",
                            "match": "\\\\."
                        }
                    ]
                },
                {
                    "name": "string.quoted.other.multiline.flint",
                    "begin": "`",
                    "end": "`"
                }
            ]
        },
        "keywords": {
            "patterns": [
                {
                    "name": "keyword.control.flint",
                    "match": "\\b(if|else|for|in|return)\\b"
                },
                {
                    "name": "storage.type.flint",
                    "match": "\\b(fn|const|var|void|string|int|bool)\\b"
                },
                {
                    "name": "constant.language.boolean.flint",
                    "match": "\\b(true|false)\\b"
                }
            ]
        },
        "operators": {
            "patterns": [
                {
                    "name": "keyword.operator.pipeline.flint",
                    "match": "~>"
                },
                {
                    "name": "keyword.operator.logical.flint",
                    "match": "\\b(not|and|or)\\b"
                },
                {
                    "name": "keyword.operator.flint",
                    "match": "(==|!=|<=|>=|\\+|-|\\*|/|%|<|>|=)"
                }
            ]
        },
        "functions": {
            "patterns": [
                {
                    "name": "entity.name.function.flint",
                    "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\s*(?=\\()"
                }
            ]
        },
        "numbers": {
            "patterns": [
                {
                    "name": "constant.numeric.flint",
                    "match": "\\b\\d+(\\.\\d+)?\\b"
                }
            ]
        }
    }
}