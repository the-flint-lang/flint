struct GithubUser {
    login: string,
    id: int,
    hireable: bool
}

print("Fetching data...");
const payload = fetch("https://api.github.com/users/lucaas-d3v") catch |e| { exit(1); };

print("Parsing directly into strongly typed Struct...");
const user = parse_json_as(GithubUser, to_str(payload));

print("Login:");
print(user.login);

print("ID:");
print(user.id);
