import io;
import os;
import strings;
import utils;

print("Starting subprocess orchestration...");

const proc = os.spawn("cat /pasta_que_nao_existe") catch |err| { 
    print("KERNEL ERROR: Unable to spawn!");
    print(err);
    os.exit(1); 
};

print("--- MEMORY STATE ---");
print("Contents of variable proc:");
print(proc);

print("Raw value of key 'exit_code':");
print(proc["exit_code"]);

if (to_int(proc["exit_code"]) != 0) {
    print("Success! The process failed natively.");
    print("Error Code:");
    print(proc["exit_code"]);
    print("STDERR output:");
    print(proc["stderr"]);
} else {
    print("Failed to else.");
}