print("Starting subprocess orchestration...");

const proc = spawn("cat /pasta_que_nao_existe") catch |err| { 
    print("KERNEL ERROR: Unable to spawn!");
    print(err);
    exit(1); 
};

print("--- MEMORY STATE ---");
print("Contents of variable proc:");
print(proc);

print("Raw value of key 'exit_code':");
print(get(proc, "exit_code"));

print("Raw value of key 'stderr':");
print(get(proc, "stderr"));
print("--------------------------------------");

if (to_int(get(proc, "exit_code")) != 0) {
    print("Success! The process failed natively.");
    print("Error Code:");
    print(get(proc, "exit_code"));
    print("STDERR output:");
    print(get(proc, "stderr"));
} else {
    print("Failed to else. The exit_code was interpreted as 0.");
}