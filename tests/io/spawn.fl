import "std/io.fl" as io;
import "std/os.fl" as os;
import "std/strings.fl" as str;
import "std/utils.fl" as utils;

print("Starting subprocess orchestration...");

const proc = os.spawn("cat /pasta_que_nao_existe") catch |err| { 
    print("KERNEL ERROR: Unable to spawn!");
    print(err);
    os.exit(1); 
};

print("--- MEMORY STATE ---");
print("Contents of variable proc:");
print(proc);

print("Raw value of key 'exit_code':");
print(get(proc, "exit_code"));

if (str.to_int(get(proc, "exit_code")) != 0) {
    print("Success! The process failed natively.");
    print("Error Code:");
    print(get(proc, "exit_code"));
    print("STDERR output:");
    print(get(proc, "stderr"));
} else {
    print("Failed to else.");
}