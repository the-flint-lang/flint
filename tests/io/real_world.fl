import "./get_default_browser.fl" as b;

import http;
import fs;
import json;
import str;
import utils;
import process;

print("================================================");
print("    FLINT STATIC GENERATOR v1.0 (flint test)    ");
print("================================================");

print("1. Connecting with servers...");

const req = http.fetch("https://dummyjson.com/quotes/random") catch |e| {
    print(e);
    process.exit(1);
};
const data = json.parse(str.to_str(req));

const quote = str.to_str(data["quote"]);
const author = str.to_str(data["author"]);

print("2. Compiling HTML artifact in RAM...");

var html = $`<!DOCTYPE html><html><body style='font-family: system-ui; padding: 4rem; background: #1a1a1a; color: #fff;'>
<h1 style='color: #4ade80;'>Flint Philosophy</h1>
<blockquote style='font-size: 1.5rem; border-left: 4px solid #4ade80; padding-left: 1rem;'>
{quote}
</blockquote><p><b>
{author}
</b></p></body></html>
`;

print("3. Writing to hard drive...");
fs.write_file(html, "philosophy.html");
print("\nAbsolute success!");

fs.rm("philosophy.html")~> process.assert("Erro is not possible to clean philosophy.html");