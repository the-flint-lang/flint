import "std/io.fl" as io;
import "std/os.fl" as os;
import "std/strings.fl" as str;

const f = os.ls(".") catch |err| {
    print(err);
    os.exit(1);
};

var i = 0;
for line in str.to_str(f) ~> str.lines() {
    str.int_to_str(i) ~> str.concat(". ") ~> str.concat(line) ~> print();
    i = i + 1;
}