import io;
import os;

_ = os.touch("test_file") catch |err| {
    print(err);
    os.exit(1);
};

_ = os.mkdir("test_dir") catch |err| {
    print(err);
    os.exit(1);
};

_ = os.mv("test_file", "test_dir/test_file") catch |err| {
    print(err);
    os.exit(1);
};

_ = os.rm("test_dir/test_file") catch |err| {
    print(err);
    os.exit(1);
};

_ = os.rm_dir("test_dir") catch |err| {
    print(err);
    os.exit(1);
};

