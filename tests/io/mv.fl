var _ = touch("test_file") catch |err| {
    print(err);
    exit(1);
};

_ = mkdir("test_dir") catch |err| {
    print(err);
    exit(1);
};

_ = mv("test_file", "test_dir/test_file") catch |err| {
    print(err);
    exit(1);
};

_ = rm("test_dir/test_file") catch |err| {
    print(err);
    exit(1);
};

_ = rm_dir("test_dir") catch |err| {
    print(err);
    exit(1);
};

