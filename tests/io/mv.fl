import io;
import fs;
import process;

_ = fs.touch("test_file") catch |err| {
    print(err);
    process.exit(1);
};

_ = fs.mkdir("test_dir") catch |err| {
    print(err);
    process.exit(1);
};

_ = fs.mv("test_file", "test_dir/test_file") catch |err| {
    print(err);
    process.exit(1);
};

_ = fs.rm("test_dir/test_file") catch |err| {
    print(err);
    process.exit(1);
};

_ = fs.rm_dir("test_dir") catch |err| {
    print(err);
    process.exit(1);
};

