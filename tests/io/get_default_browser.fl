import "std/os.fl" as os;
import "std/strings.fl" as str;

fn get_brwoser_bin_path_and_exec(name: string) void {
    const path = os.exec("xdg-settings get default-web-browser") 
        ~> str.trim() 
        ~> str.split(".");
    
    const cmd = path[0] ~> str.concat(" ") ~> str.concat(name);
    os.exec(cmd);
}