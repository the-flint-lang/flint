print("Filtering only Login via Pipeline:");

(fetch("https://api.github.com/users/lucaas-d3v") 
    catch |e| { print("Erro de rede"); exit(1); })
    ~> to_str()
    ~> split(",")
    ~> grep("\"login\":")
    ~> join("")
    ~> replace("{", "")
    ~> replace("\"", "")
    ~> replace(":", " -> ")
    ~> trim()
    ~> print();