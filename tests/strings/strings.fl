import io;
import str;

const log_sujo = "   ERROR:  banco de dados falhou, ERROR:  timeout na rede   ";

print("Processando o log...");

const partes = log_sujo 
    ~> str.replace("ERROR: ", "[FALHA]")
    ~> str.split(",");

for pedaco in partes {
    print("Encontrado:");
    print(str.trim(to_str(pedaco))); 
}