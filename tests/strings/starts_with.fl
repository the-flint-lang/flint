import str;
import fs;

for file in fs.ls(".") ~> lines() {
    if (str.starts_with(to_str(file), "start")){
        print($"{file} is a flint starts_with test source code.");
    }
    
    if (str.starts_with(to_str(file), "end")){
        print($"{file} is a flint ends_with source code.");
    }

}