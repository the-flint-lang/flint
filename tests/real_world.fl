import "get_default_browser.fl";

print("================================================");
print("    FLINT STATIC GENERATOR v1.0 (flint test)    ");
print("================================================");

print("1. Connecting with servers...");

const req = fetch("https://dummyjson.com/quotes/random") catch |e| {
    print(e);
    exit(1);
};
const data = parse_json(to_str(req));

const quote = to_str(get(data, "quote"));
const author = to_str(get(data, "author"));

print("2. Compiling HTML artifact in RAM...");

var html = "<!DOCTYPE html><html><body style='font-family: system-ui; padding: 4rem; background: #1a1a1a; color: #fff;'>"
    ~> concat("<h1 style='color: #4ade80;'>Flint Philosophy</h1>")
    ~> concat("<blockquote style='font-size: 1.5rem; border-left: 4px solid #4ade80; padding-left: 1rem;'>")
    ~> concat(quote)
    ~> concat("</blockquote><p><b>- ")
    ~> concat(author)
    ~> concat("</b></p></body></html>");

print("3. Writing to hard drive...");
write_file(html, "philosophy.html");

print("\nAbsolute success!");

print("Opening html file");
#get_brwoser_bin_path_and_exec("philosophy.html");