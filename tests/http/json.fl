import io;
import http;
import json;
import strings;
import utils;
import os;

print("Fetching data from GitHub...");

const raw_payload = http.fetch("https://api.github.com/users/lucaas-d3v") catch |e| {
    print(e);
    os.exit(1);
};

const my_profile = json.parse(strings.to_str(raw_payload));

print("\n=== DEVELOPER PROFILE ===");
print("Login:");
print(my_profile["login"]);

print("Account ID:");
print(my_profile["id"]);

print("Hireable Developer?");
print(my_profile["hireable"]);