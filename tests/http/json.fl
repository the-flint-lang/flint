import "std/io.fl" as io;
import "std/http.fl" as http;
import "std/json.fl" as json;
import "std/strings.fl" as str;
import "std/utils.fl" as utils;
import "std/os.fl" as os;

print("Fetching data from GitHub...");

const raw_payload = http.fetch("https://api.github.com/users/lucaas-d3v") catch |e| {
    print(e);
    os.exit(1);
};

const my_profile = json.parse(str.to_str(raw_payload));

print("\n=== DEVELOPER PROFILE ===");
print("Login:");
print(get(my_profile, "login"));

print("Account ID:");
print(get(my_profile, "id"));

print("Hireable Developer?");
print(get(my_profile, "hireable"));