import io;
import http;
import os;
import strings;

print("Starting critical network routine (Zig Style)...");

const request = http.fetch("https://fake-url-by-lucas.com") catch |err| {
    print("A failure occurred, but the OS DID NOT PANIC!");
    print("Intercepted technical reason: ");
    print(err);
    
    print("\nExecuting contingency and exiting gracefully...");
    os.exit(0);
};

print("Network success!");
print(strings.to_str(request));