import io;
import http;
import os;
import strings;

struct GithubUser {
    login: string,
    id: int,
    hireable: bool
}

print("Fetching data...");
const payload = http.fetch("https://api.github.com/users/lucaas-d3v") catch |e| { os.exit(1); };

print("Parsing directly into strongly typed Struct...");
const user = parse_json_as(GithubUser, strings.to_str(payload));

print("Login:");
print(user.login);

print("ID:");
print(user.id);