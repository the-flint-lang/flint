import io;
import utils;

var log_erros = ["timeout", "404"];

print("Tamanho original:");
print(len(log_erros));
print("");

print("Adicionando novos erros...");
push(log_erros, "500 Internal Server Error");
push(log_erros, "Conexao Recusada");
push(log_erros, "Segfault");
print("");

print("Tamanho apos mutacao:");
print(len(log_erros));
print("");

print("Listando os logs coletados:");
for erro in log_erros {
    print(erro);
}