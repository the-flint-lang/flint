# std/io.fl

extern fn flint_read_line() string;
extern fn flint_read_file(path: string) val;
extern fn flint_write_file(text: string, path: string) val;

# public API

fn read_line() string {
    return flint_read_line();
}

fn read_file(path: string) val {
    return flint_read_file(path);
}

fn write_file(text: string, path: string) val {
    return flint_write_file(text, path);
}