# std/env.fl
extern fn flint_env_get(name: string) string;
extern fn flint_env_set(name: string, value: string) void;
extern fn flint_env_exists(name: string) bool;

# public API
fn get(name: string) string {
    return flint_env_get(name); 
}

fn set(name: string, value: string) void {
    flint_env_set(name, value);
}

fn exists(name: string) bool {
    return flint_env_exists(name);
}
