import "std/os.fl" as os;
import "std/strings.fl" as str;

const files = os.ls(".") catch |err| { os.exit(1); };
var count = 0;
var total_size = 0;

for f in str.to_str(files) ~> str.lines() {
    if (os.is_file(f)) {
        total_size = total_size + str.to_int(os.file_size(f));
        count = count + 1;
    }
}
print("Flint processed the metadata successfully.");
