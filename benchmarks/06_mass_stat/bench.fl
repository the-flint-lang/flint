const files = ls(".") catch |err| { exit(1); };

var count = 0;
var total_size = 0;

for f in to_str(files) ~> lines() {
    # Ignore the test scripts themselves
    if (is_file(f)) {
        total_size = total_size + to_int(file_size(f));
        count = count + 1;
    }
}

print("Flint processed the metadata successfully.");