import "std/os.fl" as os;
import "std/strings.fl" as str;

const cmd = "hyperfine "
    ~> str.concat(" --min-runs 5")
    ~> str.concat(" --show-output")
    ~> str.concat(" --prepare 'sync; echo 3 | tee /proc/sys/vm/drop_caches || true' ")
    ~> str.concat(" --cleanup 'rm -f clone*.bin' ")
    ~> str.concat(" './bench' 'python3 bench.py' 'bash bench.sh'");

const result = os.exec(cmd);
