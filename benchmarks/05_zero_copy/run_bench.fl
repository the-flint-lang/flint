import os;
import strings;

const cmd = "hyperfine "
    ~> strings.concat(" --min-runs 5")
    ~> strings.concat(" --show-output")
    ~> strings.concat(" --prepare 'sync; echo 3 | tee /proc/sys/vm/drop_caches || true' ")
    ~> strings.concat(" --cleanup 'rm -f clone*.bin' ")
    ~> strings.concat(" './bench' 'python3 bench.py' 'bash bench.sh'");

const result = os.exec(cmd);
