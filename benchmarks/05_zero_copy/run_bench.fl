const cmd = "hyperfine "
    ~> concat(" --min-runs 5")
    ~> concat(" --show-output")
    ~> concat(" --prepare 'sync; echo 3 | tee /proc/sys/vm/drop_caches || true' ")
    ~> concat(" --cleanup 'rm -f clone*.bin' ")
    ~> concat(" './bench' 'python3 bench.py' 'bash bench.sh'");


const result = exec(cmd);